{
  "name": "Report",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Short headline for the report"
    },
    "category": {
      "type": "string",
      "enum": [
        "broken_pipe",
        "pothole",
        "garbage_dump",
        "streetlight",
        "drainage",
        "road_damage",
        "water_supply",
        "electricity",
        "other"
      ],
      "description": "Category of the civic issue"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the issue"
    },
    "photo_url": {
      "type": "string",
      "description": "URL of the uploaded photo"
    },
    "latitude": {
      "type": "number",
      "description": "GPS latitude"
    },
    "longitude": {
      "type": "number",
      "description": "GPS longitude"
    },
    "village": {
      "type": "string",
      "description": "Village or locality name"
    },
    "status": {
      "type": "string",
      "enum": [
        "red",
        "yellow",
        "green"
      ],
      "default": "red",
      "description": "Red=Awaiting Fix, Yellow=Workers On Site, Green=Resolved"
    },
    "community_boosts": {
      "type": "number",
      "default": 0,
      "description": "Number of community members who verified work is happening"
    },
    "boosted_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Emails of users who boosted this report"
    }
  },
  "required": [
    "title",
    "category",
    "photo_url",
    "latitude",
    "longitude",
    "village"
  ]
}